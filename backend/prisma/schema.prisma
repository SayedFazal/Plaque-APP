// PostgreSQL is the only provider, in development and in production alike.
//
// The tempting shortcut is SQLite locally and Postgres when deployed. Don't: the two disagree
// about case sensitivity, dates and unique constraints, and you find out which at 2am the night
// before the demo. One provider, one set of behaviours.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // bcrypt hash. The plaintext password never leaves the request handler.
  passwordHash  String
  name          String
  emailVerified Boolean   @default(false)
  disabled      Boolean   @default(false)

  // Brute-force tracking. Counted per account, reset on a successful sign-in.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  authTokens    AuthToken[]
  scans         Scan[]

  @@index([email])
}

/// One daily gum scan — the compliance action the whole product is built around (Module 3).
///
/// [localDate] is the calendar day the scan counts for, in the user's own timezone, sent by the
/// client as a plain "YYYY-MM-DD" string. It is stored explicitly rather than derived from
/// [capturedAt] because "did they scan today?" and streak math are questions about the user's local
/// calendar, and answering them from a UTC timestamp is where the off-by-one-at-11pm bugs live. The
/// unique [userId, localDate] makes "one scan per day" a database invariant, so a double-tap or a
/// retry can never inflate a streak.
///
/// The captured image itself is not stored here yet: uploading and analysing it is Module 4/5. This
/// row is the record that the daily action happened, which is all the dashboard's streak, count and
/// compliance score need.
model Scan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capturedAt DateTime @default(now())
  localDate  String
  createdAt  DateTime @default(now())

  @@unique([userId, localDate])
  @@index([userId])
}

/// Long-lived refresh tokens, one row per active device.
///
/// Only the SHA-256 of the token is stored. If the database leaks, the rows are useless -- the
/// same reason passwords are hashed. Rotation is enforced by marking the old row revoked on every
/// refresh, so a stolen token that gets used a second time is detectable.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Single-use, short-lived tokens sent by email: address verification and password reset.
///
/// Same rule as refresh tokens -- hashed at rest. `usedAt` makes them one-shot, so a reset link
/// forwarded or left in an inbox cannot be replayed.
model AuthToken {
  id        String        @id @default(cuid())
  tokenHash String        @unique
  type      AuthTokenType
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, type])
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
