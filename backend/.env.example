NODE_ENV=development
PORT=3000

# Postgres. Free options that need no local install and work from Render too:
#   Neon     https://neon.tech      (permanent free tier, no card)
#   Supabase https://supabase.com
# Copy the "connection string" / "pooled connection" URI here.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Two DIFFERENT values. Sharing one secret would let an access token be replayed as a refresh token.
JWT_ACCESS_SECRET="change-me-min-32-chars"
JWT_REFRESH_SECRET="change-me-min-32-chars-and-different"

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Public URL of THIS server. The links inside emails are built from it.
# Local: http://localhost:3000   Deployed: https://your-app.onrender.com
APP_BASE_URL=http://localhost:3000

# Optional. Leave blank and emails are printed to the terminal instead of sent,
# so the whole flow works before you have a mail provider.
# Gmail: host smtp.gmail.com, port 587, user your@gmail.com,
#        pass = a 16-char App Password (NOT your Google password; needs 2FA on).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM="PerioCompliance AI <no-reply@periocompliance.ai>"
