<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      The app talks HTTPS to the deployed backend and nothing else. Cleartext HTTP is denied
      outright: a blanket android:usesCleartextTraffic="true", or an exemption for loopback, would
      let an attacker on the same Wi-Fi downgrade a real API call to HTTP and read the bearer token
      off the wire. minSdk is 26, where cleartext is permitted by default, so this rule is what
      actually enforces HTTPS-only on those API levels.
    -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
